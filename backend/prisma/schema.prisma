// Prisma schema for CricBid — migration target (PostgreSQL)
// Models mirror the existing Mongoose schemas in ../models.
// IDs are String so the existing Mongo ObjectId hex values can be carried over
// during ETL, preserving the `_id` contract the frontend/mobile already use.
// New rows get a cuid().
//
// NOTE: analytics READ pipelines are intentionally not ported yet (Analytics
// page is hidden). The log tables below (UserEvent, WhatsappLog, IpGeoCache)
// are still WRITTEN during normal operation, so they are migrated.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums (well-bounded sets enforced by the app today)
// ---------------------------------------------------------------------------

enum Role {
  boss
  super_user
  tournament_host
}

enum AuctionMode {
  category
  manual
}

enum AuctionLogStatus {
  sold
  unsold
}

enum SessionStatus {
  active
  ended
  abandoned
}

// ---------------------------------------------------------------------------
// Core entities
// ---------------------------------------------------------------------------

model User {
  id       String  @id @default(cuid())
  name     String?
  email    String  @unique
  password String
  role     Role    @default(tournament_host)
  isActive Boolean @default(true)
  logo     String?

  // permissions{} object flattened to columns
  canCreateSuperUser      Boolean @default(false)
  canCreateTournamentHost Boolean @default(false)
  canManageTournaments    Boolean @default(true)
  canManageTeams          Boolean @default(true)
  canManagePlayers        Boolean @default(true)

  // self-relation: who created this user
  createdById String?
  createdBy   User?   @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers User[] @relation("UserCreatedBy")

  // back-relations
  auctionLogs        AuctionLog[]         @relation("AuctionLogConductedBy")
  auctionRoomSessions AuctionRoomSession[] @relation("SessionHost")
  userEvents         UserEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user")
}

model Tournament {
  id                String  @id @default(cuid())
  name              String?
  tournamentHostId  String?
  noOfTeams         Int?
  maxPlayersPerTeam Int?
  minPlayersPerTeam Int?
  totalBudget       Int?

  playerCategories     String[] // Postgres text[]
  categoryBasePrices   Json?    // Map<string, number>
  bidIncrementSlabs    Json?    // [{ minBid, maxBid, increment }]
  registrationFormConfig Json?  // deeply nested config blob
  features               Json?  // { whatsappNotifications, obsOverlays, publicPlayerRegistration, publicTeamRegistration, googleSheetsSync, dataExport }
  whatsappConfig         Json?  // per-tournament WhatsApp template toggles — see WhatsApp config schema docs

  // back-relations
  players             Player[]
  teams               Team[]
  auctionLogs         AuctionLog[]
  auctionRoomSessions AuctionRoomSession[]
  userEvents          UserEvent[]
  whatsappLogs        WhatsappLog[]
  backups             TournamentBackup[]
  matches             Match[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tournament")
}

model Team {
  id   String  @id @default(cuid())
  name String?
  logo String?

  // owner{} object flattened
  ownerName  String?
  ownerEmail String?
  ownerMobile String?

  // NOTE: column kept as the existing (misspelled) `touranmentId` to preserve
  // the current API contract; rename is a separate cleanup.
  touranmentId String?
  tournament   Tournament? @relation(fields: [touranmentId], references: [id])

  players        Player[]
  wonAuctionLogs AuctionLog[]     @relation("AuctionLogWinningTeam")
  bids           AuctionLogBid[]
  homeMatches    Match[]          @relation("MatchTeamA")
  awayMatches    Match[]          @relation("MatchTeamB")
  battingInnings Innings[]        @relation("InningsBattingTeam")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("team")
}

model Player {
  id     String  @id @default(cuid())
  name   String?
  age    Int?
  gender String?
  photo  String?
  skill  String?
  // NOTE: was Mongoose Number; stored as String here because 10-digit phone
  // numbers overflow Int. API serialization may need to cast. (flag for review)
  mobile String?
  email  String?
  address String?

  touranmentId String?
  tournament   Tournament? @relation(fields: [touranmentId], references: [id])

  teamId String?
  team   Team?  @relation(fields: [teamId], references: [id])

  sold                Boolean?
  auctionStatus       Boolean?
  amtSold             Int?
  playerCategory      String?
  auctionSerialNumber Int?
  customFields        Json?   // Map<string, mixed>

  auctionLogs  AuctionLog[]
  whatsappLogs WhatsappLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("player")
}

// ---------------------------------------------------------------------------
// Auction history
// ---------------------------------------------------------------------------

model AuctionLog {
  id String @id @default(cuid())

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id])

  playerId String
  player   Player @relation(fields: [playerId], references: [id])

  playerName     String?
  playerCategory String?
  basePrice      Int

  auctionMode AuctionMode

  status          AuctionLogStatus
  winningTeamId   String?
  winningTeam     Team?   @relation("AuctionLogWinningTeam", fields: [winningTeamId], references: [id])
  winningTeamName String?
  finalPrice      Int?

  // embedded bids[] -> child table
  bids AuctionLogBid[]

  totalBids          Int @default(0)
  uniqueTeamsBidding Int @default(0)

  auctionStartedAt     DateTime?
  auctionEndedAt       DateTime?
  totalDurationSeconds Int?

  conductedById String?
  conductedBy   User?   @relation("AuctionLogConductedBy", fields: [conductedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tournamentId, status])
  @@index([tournamentId, playerCategory])
  @@index([playerId, auctionStartedAt])
  @@index([tournamentId, auctionEndedAt])
  @@map("auction_log")
}

model AuctionLogBid {
  id String @id @default(cuid())

  auctionLogId String
  auctionLog   AuctionLog @relation(fields: [auctionLogId], references: [id], onDelete: Cascade)

  teamId   String
  team     Team   @relation(fields: [teamId], references: [id])
  teamName String

  bidAmount    Int
  bidIncrement Int?
  timestamp    DateTime?
  bidOrder     Int

  @@index([auctionLogId, bidOrder])
  @@map("auction_log_bid")
}

// ---------------------------------------------------------------------------
// Live auction room session analytics (write-side migrated; reads deferred)
// ---------------------------------------------------------------------------

model AuctionRoomSession {
  id String @id @default(cuid())

  tournamentId   String
  tournament     Tournament @relation(fields: [tournamentId], references: [id])
  tournamentName String?

  sessionStartedAt        DateTime?
  sessionEndedAt          DateTime?
  sessionDurationMinutes  Int?

  hostUserId   String?
  hostUser     User?   @relation("SessionHost", fields: [hostUserId], references: [id])
  hostUserName String?

  // arrays kept as Postgres text[] / Json
  uniqueViewerUserIds String[]
  anonymousViewerIPs  String[]

  totalUniqueViewers Int @default(0)
  totalJoins         Int @default(0)

  peakConcurrentViewers Int      @default(0)
  peakViewerTimestamp   DateTime?

  playersAuctioned Int @default(0)
  playersSold      Int @default(0)
  playersUnsold    Int @default(0)
  totalBids        Int @default(0)

  viewerHistory Json? // [{ timestamp, viewerCount }]

  status SessionStatus @default(active)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tournamentId, sessionStartedAt])
  @@index([status, sessionStartedAt])
  @@index([hostUserId, sessionStartedAt])
  @@map("auction_room_session")
}

// ---------------------------------------------------------------------------
// Logging / cache tables (written in normal flow)
// ---------------------------------------------------------------------------

model UserEvent {
  id String @id @default(cuid())

  userId String?
  user   User?  @relation(fields: [userId], references: [id])

  sessionId String?

  tournamentId String?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id])

  eventType String // open-ended enum kept as String
  eventData Json?

  page      String?
  userAgent String?
  ipAddress String?

  timestamp DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tournamentId, eventType, timestamp])
  @@index([userId, timestamp])
  @@index([sessionId, timestamp])
  @@map("user_event")
}

model WhatsappLog {
  id String @id @default(cuid())

  messageType     String
  templateName    String?
  recipientMobile String

  playerId   String?
  player     Player? @relation(fields: [playerId], references: [id])
  playerName String?

  tournamentId   String?
  tournament     Tournament? @relation(fields: [tournamentId], references: [id])
  tournamentName String?

  teamName String?
  amtSold  Int?

  status       String
  messageId    String?
  errorMessage String?

  timestamp DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, timestamp])
  @@index([messageType, timestamp])
  @@index([tournamentId, timestamp])
  @@map("whatsapp_log")
}

// ---------------------------------------------------------------------------
// Match schedule & score tracker
// ---------------------------------------------------------------------------

enum MatchStatus {
  upcoming
  live
  completed
  cancelled
  no_result
}

enum MatchFormat {
  T20
  ODI
  T10
  custom
}

model Match {
  id           String      @id @default(cuid())
  tournamentId String
  tournament   Tournament  @relation(fields: [tournamentId], references: [id])

  matchNumber  Int?
  round        String?     // "League", "Quarter Final", "Semi Final", "Final"
  venue        String?
  scheduledAt  DateTime?
  format       MatchFormat @default(T20)
  totalOvers   Int         @default(20)

  teamAId      String
  teamA        Team        @relation("MatchTeamA", fields: [teamAId], references: [id])
  teamBId      String
  teamB        Team        @relation("MatchTeamB", fields: [teamBId], references: [id])

  status       MatchStatus @default(upcoming)
  tossWonById  String?     // team id
  tossDecision String?     // "bat" | "field"

  winnerId     String?     // team id, null if tie/no result
  resultNote   String?     // "Team A won by 5 wickets", auto-generated or manual override

  innings      Innings[]

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([tournamentId, scheduledAt])
  @@index([tournamentId, status])
  @@map("match")
}

model Innings {
  id            String  @id @default(cuid())
  matchId       String
  match         Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  inningsNumber Int     // 1 or 2
  battingTeamId String
  battingTeam   Team    @relation("InningsBattingTeam", fields: [battingTeamId], references: [id])

  runs          Int     @default(0)
  wickets       Int     @default(0)
  oversBowled   Float   @default(0) // e.g. 18.4 means 18 overs 4 balls
  extras        Int     @default(0)
  isCompleted   Boolean @default(false)

  // ball-by-ball back-relations
  ballEvents     BallEvent[]
  batsmanInnings BatsmanInnings[]
  bowlerInnings  BowlerInnings[]
  partnerships   Partnership[]
  fallOfWickets  FallOfWicket[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([matchId, inningsNumber])
  @@map("innings")
}

// ---------------------------------------------------------------------------
// Ball-by-ball scoring
// ---------------------------------------------------------------------------

enum WicketType {
  bowled
  caught
  lbw
  run_out
  stumped
  hit_wicket
  handled_ball
  obstructing_field
  timed_out
  retired_hurt
}

enum ExtraType {
  wide
  no_ball
  bye
  leg_bye
  penalty
}

// One row per legal delivery (and extras that don't count as a legal ball are
// still stored but isLegalDelivery=false so over ball counts stay correct).
model BallEvent {
  id            String   @id @default(cuid())
  inningsId     String
  innings       Innings  @relation(fields: [inningsId], references: [id], onDelete: Cascade)
  matchId       String   // denormalised for easy queries
  inningsNumber Int

  overNumber    Int      // 0-indexed: over 1 = overNumber 0
  ballInOver    Int      // 1-indexed within that over (legal deliveries only)
  isLegalDelivery Boolean @default(true)

  // who is involved
  batsmanId     String   // Player id (from Player table)
  nonStrikerId  String?  // for context
  bowlerId      String   // Player id

  // runs off the bat
  batRuns       Int      @default(0)

  // extras
  isExtra       Boolean  @default(false)
  extraType     ExtraType?
  extraRuns     Int      @default(0) // runs from extras (not bat)

  // total runs on this delivery = batRuns + extraRuns
  totalRuns     Int      @default(0)

  // wicket
  isWicket      Boolean  @default(false)
  wicketType    WicketType?
  outBatsmanId  String?  // who got out (may differ from batsmanId on run-out)
  fielderId     String?  // catcher / fielder on run-out

  // auto-generated ball commentary e.g. "OUT! Bowled Mehta. Sharma b Mehta 18(22)"
  commentary    String?

  createdAt     DateTime @default(now())

  @@index([inningsId, overNumber, ballInOver])
  @@index([matchId, inningsNumber])
  @@map("ball_event")
}

// Batting scorecard row — one per batsman per innings
model BatsmanInnings {
  id            String   @id @default(cuid())
  inningsId     String
  innings       Innings  @relation(fields: [inningsId], references: [id], onDelete: Cascade)
  matchId       String
  inningsNumber Int

  playerId      String   // Player id
  teamId        String
  battingOrder  Int      // 1 = opener

  runs          Int      @default(0)
  ballsFaced    Int      @default(0)
  fours         Int      @default(0)
  sixes         Int      @default(0)

  isOut         Boolean  @default(false)
  howOut        String?  // "c Patel b Mehta" — human-readable
  wicketType    WicketType?
  bowlerId      String?  // credited bowler
  fielderId     String?  // catcher / fielder

  didNotBat     Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([inningsId, playerId])
  @@index([matchId, inningsNumber])
  @@map("batsman_innings")
}

// Bowling scorecard row — one per bowler per innings
model BowlerInnings {
  id            String   @id @default(cuid())
  inningsId     String
  innings       Innings  @relation(fields: [inningsId], references: [id], onDelete: Cascade)
  matchId       String
  inningsNumber Int

  playerId      String   // Player id
  teamId        String

  balls         Int      @default(0)  // legal deliveries
  runs          Int      @default(0)  // runs conceded
  wickets       Int      @default(0)
  maidens       Int      @default(0)
  wides         Int      @default(0)
  noBalls       Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([inningsId, playerId])
  @@index([matchId, inningsNumber])
  @@map("bowler_innings")
}

// Partnership between any two batsmen
model Partnership {
  id            String   @id @default(cuid())
  inningsId     String
  innings       Innings  @relation(fields: [inningsId], references: [id], onDelete: Cascade)
  matchId       String

  wicketNumber  Int      // 1 = opening partnership, 2 = 2nd wicket, etc.
  batsman1Id    String
  batsman2Id    String

  runs          Int      @default(0)
  balls         Int      @default(0)

  createdAt     DateTime @default(now())

  @@unique([inningsId, wicketNumber])
  @@map("partnership")
}

// Fall of wickets — one row per wicket that fell
model FallOfWicket {
  id            String   @id @default(cuid())
  inningsId     String
  innings       Innings  @relation(fields: [inningsId], references: [id], onDelete: Cascade)
  matchId       String

  wicketNumber  Int      // 1..10
  playerId      String   // batsman who got out
  runs          Int      // team score at time of wicket
  balls         Int      // total legal balls bowled at time of wicket
  overNumber    Int
  ballInOver    Int

  createdAt     DateTime @default(now())

  @@unique([inningsId, wicketNumber])
  @@map("fall_of_wicket")
}

model TournamentBackup {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  label        String?    // optional user-provided name
  snapshot     Json       // { players: [{id, name, sold, auctionStatus, teamId, amtSold}] }
  playerCount  Int        @default(0)
  soldCount    Int        @default(0)
  createdAt    DateTime   @default(now())

  @@map("tournament_backup")
}

model IpGeoCache {
  id        String  @id @default(cuid())
  ipAddress String  @unique
  city      String?
  region    String?
  country   String?
  countryCode String?
  lat       Float?
  lon       Float?
  isp       String?
  isValid   Boolean @default(true)
  // NOTE: Mongo had a 30d TTL index here. Postgres has no native TTL —
  // needs a periodic cleanup job on cachedAt. (flag for review)
  cachedAt  DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ip_geo_cache")
}
